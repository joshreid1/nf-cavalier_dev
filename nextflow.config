
params {
    /* ============= PRIMARY I/O PARAMS ============== */
    outdir = 'output'
    bams = null
    lists = null
    ped = null // optional - required if familial structure
    short_vcf = null
    short_vcf_annotated = null // skip annotation by providing pre-annotated VCF (output from another run)
    struc_vcf = '' // not implemented
    struc_vcf_annotated = null // not implemented
   
    /* ============= MISC PARAMS =============*/
    annotate_only = false // will not filter and report variants
    no_slides = false // skip making slides
    // ref fasta
    ref_fasta = '/vast/projects/bahlo_cache/ref_genome/hg38_GATK/Homo_sapiens_assembly38.fasta'
    // used by cavalier R package - can point to a unified cache else will create in working directory
    cavalier_cache_dir = 'cavalier_cache'
    // additional options for cavalier R pacakge
    cavalier_options = [ read_only_cache_dir: '/cavalier_cache'] // will use cache files from but here won't write to

    /* ================ VEP PARAMS ================ */
    vep_cache     = '/vast/projects/bahlo_cache/vep_cache'
    vep_cache_ver = '115'
    // check number of variants output by VEP equal to number input
    vep_check     = true
    // VEP plugins (setting to null will disable plugin)
    vep_spliceai_snv   = '/vast/projects/bahlo_cache/annotation/spliceAI/1.3/spliceai_scores.raw.snv.hg38.vcf.gz'
    vep_spliceai_indel = '/vast/projects/bahlo_cache/annotation/spliceAI/1.3/spliceai_scores.raw.indel.hg38.vcf.gz'
    vep_alphamissense  = '/vast/projects/bahlo_cache/annotation/alphamissense/AlphaMissense_hg38.tsv.gz'
    vep_revel          = '/vast/projects/bahlo_cache/annotation/REVEL/revel_1.3.hg38.vep.tsv.gz'
    vep_utr_annotator  = '/vast/projects/bahlo_cache/annotation/UTRannotator/uORF_5UTR_GRCh38_PUBLIC.txt'


    /* =================== SHORT VARIANT PARAMS =================== */
    // split input VCF into shards for parallel processing
    short_n_shards = 200
    // apply filter to input variants
    short_vcf_filter = "PASS,."
    // INFO fields to keep from VCF
    short_info = ['AC', 'AF', 'AN']
    // FORMAT fields to keep from VCF
    short_format = ['GT', 'GQ', 'DP'] // TODO: ensure 'GT' is always present
    // fill AC, AF, and AN from VCF - recommended to set true if VCF does not have these set
    short_fill_tags = false
    // vcfanno settings
    vcfanno_binary = 'https://github.com/brentp/vcfanno/releases/download/v0.3.7/vcfanno_linux64'
    short_vcfanno = [
        [   vcf: '/vast/projects/bahlo_cache/annotation/gnomAD/joint_sites_4.1.vcf.gz', 
            csi: true, 
            fields: [gnomad_AF: 'AF', gnomad_AC: 'AC', gnomad_FAF95: 'fafmax_faf95_max', gnomad_nhomalt: 'nhomalt']
        ],
        [   tsv: '/vast/projects/bahlo_cache/annotation/CADD/1.7/whole_genome_SNVs.tsv.gz',
            fields: [CADD: 6]
        ],
        [   tsv: '/vast/projects/bahlo_cache/annotation/CADD/1.7/gnomad.genomes.r4.0.indel.tsv.gz',
            csi: true,
            fields: [CADD: 6]
        ],
        [   tsv: '/vast/projects/bahlo_cache/annotation/CADD/1.7/gnomad.joint.r4.1.indel.tsv.bgz',
            csi: true,
            fields: [CADD: 6]
        ],
        [   tsv: '/vast/projects/bahlo_cache/annotation/phyloP/hg38.phyloP100way.bed.gz',
            fields: [phyloP100: 4],
            op: 'max'
        ],
        [   vcf: '/vast/projects/bahlo_cache/annotation/ClinVar/clinvar_20260114.vcf.gz',
            csi: true,
            fields: [CLNSIG: 'CLNSIG', CLNGENE: 'GENEINFO',  CLNVID: 'ID']
        ]
    ]
    // filter to apply after VCF anno, drastically reduces VEP runtime if we drop common variants
    short_vcfanno_filter = 'gnomad_AF<0.01 || gnomad_AF="."' // (keep if AF < 0.01 or AF is missing)
    

    /* =================== FILTERING PARAMS =================== */
    // filters can be disabled by setting = null
    FILTER_SHORT_MIN_DP = 5
    FILTER_SHORT_MIN_GQ = 10
    // short variant population (gnomAD) filters
    FILTER_SHORT_POP_DOM_MAX_AF = 0.0001
    FILTER_SHORT_POP_REC_MAX_AF = 0.01
    FILTER_SHORT_POP_DOM_MAX_AC = 20
    FILTER_SHORT_POP_REC_MAX_AC = 100
    FILTER_SHORT_POP_DOM_MAX_HOM = 5
    FILTER_SHORT_POP_REC_MAX_HOM = 10
    // short variant cohort filters
    FILTER_SHORT_COH_DOM_MAX_AF = null
    FILTER_SHORT_COH_REC_MAX_AF = null
    FILTER_SHORT_COH_DOM_MAX_AC = null
    FILTER_SHORT_COH_REC_MAX_AC = null
    // ClinVar significance filters (regex)
    FILTER_SHORT_CLINVAR_LIST_ONLY = true
    FILTER_SHORT_CLINVAR_KEEP_PAT  = '(p|P)athogenic(?!ity)'
    FILTER_SHORT_CLINVAR_DISC_PAT  = '(b|B)enign'
    // misc filters
    FILTER_SHORT_LOF              = true // enable TYPE='LOF' (VEP IMPACT == 'HIGH')
    FILTER_SHORT_MISSENSE         = true // enable TYPE='MISSENSE' (VEP CSQ contains 'missense')
    FILTER_SHORT_SPLICING         = true // enable TYPE='SPLICING'
    FILTER_SHORT_MIN_CADD_PP      = 25.3 // Clingen PP3 supporting  doi: 10.1016/j.ajhg.2022.10.013
    FILTER_SHORT_MIN_SPLICEAI_PP  = 0.20 //Clingen PP3 supporting https://doi.org/10.1016/j.ajhg.2023.06.002
    FILTER_SHORT_VEP_MIN_IMPACT   = 'MODERATE' // will retain all variants with at least this impact as OTHER
    FILTER_SHORT_VEP_CONSEQUENCES = null // will retain all variants with these CSQs as OTHER

    // structural variant population (gnomAD) filters
    FILTER_STRUC_POP_DOM_MAX_AF = 0.0001
    FILTER_STRUC_POP_REC_MAX_AF = 0.01
    FILTER_STRUC_POP_DOM_MAX_HOM = null
    FILTER_STRUC_POP_REC_MAX_HOM = null
    // strucutural  variant cohort filters
    FILTER_STRUC_COH_DOM_MAX_AF = 0.01
    FILTER_STRUC_COH_REC_MAX_AF = 0.01
    FILTER_STRUC_COH_DOM_MAX_AC = null
    FILTER_STRUC_COH_REC_MAX_AC = null
    FILTER_STRUC_SVTYPES          = 'DEL,DUP,INS,INV,BND'
    FILTER_STRUC_VEP_MIN_IMPACT   = 'LOW'
    FILTER_STRUC_VEP_CONSEQUENCES = 'coding_sequence_variant,non_coding_transcript_exon_variant,TFBS_ablation,regulatory_region_ablation,intron_variant'
    FILTER_STRUC_LARGE_LENGTH     = 500000 // variants larger than this are automatically reported

    /* =================== REPORTING PARAMS =================== */
    // DEFAULT is required
    SLIDE_INFO_SHORT = [
        DEFAULT: [
            Gene         : 'Gene',
            Inheritance  : 'inheritance', 
            Consequence  : 'Consequence',
            HGVS         : 'HGVS',
            ClinVar      : 'CLNSIG',
            'gnomAD v4.1': 'gnomAD', 
            Cohort       : 'Cohort',
            PhyloP100    : 'phyloP100',
            SpliceAI     : 'SpliceAI',
            CADD         : 'CADD',
        ],
        MISSENSE: [
            REVEL        : 'REVEL',
            AlphaMissense: 'AlphaMissense',
            SIFT         : 'SIFT',
            PolyPhen     : 'PolyPhen',
        ]
    ]

    SLIDE_INFO_STRUC = [
        DEFAULT: [
            Gene         : 'Gene',
            Inheritance  : 'inheritance', 
            Consequence  : 'Consequence',
           'SV Type'     : 'SVTYPE',
            Chromosome   : 'CHROM',
            Position     : 'POS',
            End          : 'END',
            Length       : 'SVLEN',
            'Max Pop AF' : 'Max_AF'
        ]
    ]

    /* =================== SV PARAMS =================== */
    // ( in progress )
    struc_vcf_filter = "PASS,."
    struc_info = ['AC', 'AF', 'AN', 'SVTYPE', 'SVLEN', 'END'] // TODO: ['CHR2', 'POS2', 'END2']
    // FORMAT fields to keep from VCF
    struc_format = ['GT']
    struc_fill_tags = false
    struc_n_shards  = 20
    svafdb = '/vast/projects/bahlo_cache/annotation/SVAFotate/SVAFotate_core_SV_popAFs.GRCh38.v4.1.bed.gz'
    pop_sv = '/vast/projects/bahlo_cache/annotation/gnomAD/gnomad.v4.1.sv.sites.clean.vcf.gz'
    ref_gene = '/vast/projects/bahlo_cache/cavalier_cache/misc/ncbiRefSeqSelect.2026-01.tsv'
}


process {
    shell = ['/bin/bash', '-euo', 'pipefail']
    errorStrategy = { task.attempt <= 3 && task.errorCount < 10 ? 'retry' : 'finish' }

    withLabel: bcftools {
        container = 'quay.io/biocontainers/bcftools:1.21--h3a4d415_1'
    }

    withLabel: biopython {
        container = 'quay.io/biocontainers/biopython:1.79'
    }

    // withLabel: caddsv {
    //     container = 'ghcr.io/jemunro/cadd-sv:251216'
    // }

    withLabel: cavalier {
        // beforeScript = 'export R_LIBS_USER=/vast/projects/munro_data/software/R/4.5'
        // module = 'R/flexiblas/4.5.2'
        container = 'ghcr.io/bahlolab/cavalier:dev-251211'
    }

    withLabel: igvreports {
        container = 'quay.io/biocontainers/igv-reports:1.16.0--pyh7e72e81_0'
    }

    withLabel: vcfanno {
        container = 'quay.io/biocontainers/vcfanno:0.3.5--h9ee0642_1'
    }

    withLabel: vep {
        container = 'quay.io/biocontainers/ensembl-vep:115.2--pl5321h2a3209d_1'
    }

    withLabel: poppler {
        container = 'quay.io/biocontainers/poppler:25.07.0'
    }

    withLabel: puppeteer {
        container = 'ghcr.io/puppeteer/puppeteer:24.32.0'
    }

    withLabel: svpv {
        container = 'bahlolab/svpv:dev-23.06.2'
    }

    withLabel: samplot {
        container = 'quay.io/biocontainers/samplot:1.3.0--pyh5e36f6f_1'
    }

    
    withLabel: svafotate {
        container = 'ghcr.io/jemunro/svafotate:251217'
    }

    withLabel:C2M2T2 {
        cpus   =   2
        memory = { 2 * task.attempt + ' GB' }
        time   = { 2 * task.attempt + ' h'  }
    }

    withLabel:C2M4T4 {
        cpus   =   2
        memory = { 4 * task.attempt + ' GB' }
        time   = { 4 * task.attempt + ' h'  }
    }

    withLabel:C2M8T2 {
        cpus   =   2
        memory = { 8 * task.attempt + ' GB' }
        time   = { 2 * task.attempt + ' h'  }
    }

    withLabel:C2M16T2 {
        cpus   =   2
        memory = { 16 * task.attempt + ' GB' }
        time   = { 2 * task.attempt + ' h'   }
    }

    withLabel:C4M4T2 {
        cpus   =   4
        memory = { 4 * task.attempt + ' GB' }
        time   = { 2 * task.attempt + ' h'  }
    }
    

    withLabel:C4M8T8 {
        cpus   =   4
        memory = { 8 * task.attempt + ' GB' }
        time   = { 8 * task.attempt + ' h'  }
    }

    withLabel:C8M8T16 {
        cpus   =   8
        memory = { 8 * task.attempt + ' GB' }
        time   = { 32 * task.attempt + ' h'  }
    }
}


